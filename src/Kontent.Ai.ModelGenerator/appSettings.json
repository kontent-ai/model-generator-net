// This settings file holds default flags to pass to the application.
// Mandatory parameters not set here must be passed via command-line arguments.
// Command-line parameters always take precedence over this file.
{
  // Kontent.ai Delivery SDK options. See https://github.com/kontent-ai/delivery-sdk-net for the full set of supported options.
  "DeliveryOptions": {
    // Kontent.ai Environment ID. The default below is the public Kontent.ai sample project for quick experimentation; replace it with your own environment ID.
    "EnvironmentId": "975bf280-fd91-488c-994c-2f04416e5ee3"
  },

  // Namespace name of the generated classes. Defaults to "KontentAiModels" when null.
  "Namespace": null,

  // Output directory for the generated files.
  "OutputDir": "./output",

  // [Obsolete] Indicates whether the CustomTypeProvider class should be generated. The Delivery SDK 19+ generates its own TypeProvider via source generation.
  "WithTypeProvider": false,

  // If set, a base class is created and all generated records derive from it via partial extender records.
  "BaseClass": null
}
